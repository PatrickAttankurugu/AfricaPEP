# AfricaPEP Configuration
# Copy this file to .env and adjust as needed

# Neo4j (Graph Database - Source of Truth)
# For Docker: bolt://neo4j:7687
# For local dev: bolt://localhost:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=africapep_secret

# PostgreSQL (Search Index)
# For Docker: postgresql://africapep:africapep_secret@postgres:5432/africapep
# For local dev: postgresql://africapep:africapep_secret@localhost:5432/africapep
POSTGRES_URL=postgresql://africapep:africapep_secret@postgres:5432/africapep

# Application
LOG_LEVEL=INFO
SCRAPER_DELAY_SECONDS=2.0
ENVIRONMENT=development
