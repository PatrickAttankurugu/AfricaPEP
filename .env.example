# AfricaPEP Configuration
# Copy this file to .env and replace all CHANGEME values

# Neo4j (Graph Database - Source of Truth)
# For Docker: bolt://neo4j:7687
# For local dev: bolt://localhost:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGEME_generate_a_strong_password

# PostgreSQL (Search Index)
# For Docker: postgresql://africapep:YOUR_PASSWORD@postgres:5432/africapep
# For local dev: postgresql://africapep:YOUR_PASSWORD@localhost:5432/africapep
POSTGRES_USER=africapep
POSTGRES_PASSWORD=CHANGEME_generate_a_strong_password
POSTGRES_DB=africapep
POSTGRES_URL=postgresql://africapep:CHANGEME_generate_a_strong_password@postgres:5432/africapep

# Application
LOG_LEVEL=INFO
SCRAPER_DELAY_SECONDS=2.0
ENVIRONMENT=development
